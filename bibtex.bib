@article{zhang_whose_2019,
	title = {Whose lives matter? {Mass} shootings and social media discourses of sympathy and policy, 2012–2014},
	volume = {24},
	issn = {1083-6101},
	shorttitle = {Whose lives matter?},
	url = {https://academic.oup.com/jcmc/article/24/4/182/5489530},
	doi = {10.1093/jcmc/zmz009},
	abstract = {This study focuses on the outpouring of sympathy in response to mass shootings and the contestation over gun policy on Twitter from 2012 to 2014 and relates these discourses to features of mass shooting events. We use two approaches to Twitter text analysis—hashtag grouping and supervised machine learning (ML)—to triangulate an understanding of intensity and duration of “thoughts and prayers,” gun control, and gun rights discourses. We conduct parallel time series analyses to predict their temporal patterns in response to features of mass shootings. Our analyses reveal that while the total number of victims and child deaths consistently predicted public grieving and calls for gun control, public shootings consistently predicted the defense of gun rights. Further, the race of victims and perpetrators aﬀected the levels of public mourning and policy debates, with the loss of black lives and the violence inﬂicted by white shooters generating less sympathy and policy discourses.},
	language = {en},
	number = {4},
	urldate = {2020-06-20},
	journal = {Journal of Computer-Mediated Communication},
	author = {Zhang, Yini and Shah, Dhavan and Foley, Jordan and Abhishek, Aman and Lukito, Josephine and Suk, Jiyoun and Kim, Sang Jung and Sun, Zhongkai and Pevehouse, Jon and Garlough, Christine},
	month = jul,
	year = {2019},
	pages = {182--202},
	file = {Zhang et al_2019_Whose Lives Matter.pdf:/Users/jiyoun/My Drive/Zotero/Zhang et al_2019_Whose Lives Matter.pdf:application/pdf;zmz009_jcmc19-massshootings-appendices-final_version.pdf:/Users/jiyoun/Zotero/storage/MVRL92F2/zmz009_jcmc19-massshootings-appendices-final_version.pdf:application/pdf},
}

@article{lukito_wolves_2020,
	title = {The wolves in sheep’s clothing: {How} russia’s {Internet} {Research} {Agency} tweets appeared in {U}.{S}. news as vox populi},
	volume = {25},
	issn = {1940-1612, 1940-1620},
	shorttitle = {The wolves in sheep’s clothing},
	url = {http://journals.sagepub.com/doi/10.1177/1940161219895215},
	doi = {10.1177/1940161219895215},
	abstract = {The Russian-sponsored Internet Research Agency’s (IRA) use of social media to influence U.S. political discourse is undoubtedly troubling. However, scholarly attention has focused on social media, overlooking the role that news media within the country played in amplifying false, foreign messages. In this article, we examine articles in the U.S. news media system that quoted IRA tweets through the lens of changing journalism practices in the hybrid media system, focusing specifically on news gatekeepers’ use of tweets as vox populi. We find that a majority of the IRA tweets embedded in the news were vox populi. That is, IRA tweets were quoted (1) for their opinion, (2) as coming from everyday Twitter users, and (3) with a collection of other tweets holistically representing public sentiment. These findings raise concerns about how modern gatekeeping practices, transformed due to the hybrid media system, may also unintentionally let in unwanted disinformation from malicious actors.},
	language = {en},
	number = {2},
	urldate = {2020-06-20},
	journal = {The International Journal of Press/Politics},
	author = {Lukito, Josephine and Suk, Jiyoun and Zhang, Yini and Doroshenko, Larissa and Kim, Sang Jung and Su, Min-Hsin and Xia, Yiping and Freelon, Deen and Wells, Chris},
	month = apr,
	year = {2020},
	pages = {196--216},
	file = {Lukito et al_2020_The Wolves in Sheep’s Clothing.pdf:/Users/jiyoun/My Drive/Zotero/Lukito et al_2020_The Wolves in Sheep’s Clothing.pdf:application/pdf},
}

@inproceedings{zhang_tweeting_2017,
